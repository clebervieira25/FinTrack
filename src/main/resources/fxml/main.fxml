<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.fintrack.controller.MainController">

    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="FinTrack - Controle Financeiro" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

            <Separator/>

            <GridPane hgap="20" vgap="10">
                <Label text="Saldo Atual:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 16px;"/>
                <Label fx:id="lblSaldo" text="R$ 0,00" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-size: 18px;"/>

                <Label text="Total Receitas:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblTotalReceitas" text="R$ 0,00" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-text-fill: green;"/>

                <Label text="Total Despesas:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblTotalDespesas" text="R$ 0,00" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-text-fill: red;"/>
            </GridPane>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tabelaTransacoes">
            <columns>
                <TableColumn fx:id="colData" text="Data" prefWidth="120"/>
                <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="300"/>
                <TableColumn fx:id="colValor" text="Valor" prefWidth="150"/>
                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="100"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button text="Nova Transação" onAction="#abrirNovaTransacao" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
            <Button text="Remover" onAction="#removerTransacao" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
            <Button text="Relatório" onAction="#abrirRelatorio" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>